{"schema":1,"kind":"decision","id":"01KX4DSZGZGT7GB16NZBNAGZQZ","title":"Enable default release notices in the guard","decision":"Make the installed guard check the GitHub Releases endpoint through its existing daily cache by default and notify only when a newer version exists. Keep ELDR_UPDATE_CHECK=0 as the explicit opt-out for users who require a fully offline monitor.","alternatives":[{"option":"Keep update checks opt-in","why_rejected":"The default installation never warns the operator about a released fix, which defeats the requested update-notice behavior."},{"option":"Poll GitHub on every guard sample","why_rejected":"It would add unnecessary network traffic and notification risk; the existing 24-hour cache already bounds the check."}],"scope":["src/daemon/guard.rs,src/doctor.rs,src/update.rs,README.md,Cargo.toml,Cargo.lock,packaging/Info.plist,CHANGELOG.md"],"commits":["0088574c005f1bafe4b234507298beed1c4f16fc"],"author":"codex","confidence":"high","tags":["updates,release,notifications"],"ts":1783633870367}

{"schema":1,"kind":"decision","id":"01KX4EGWV7B935QF4PFB5C6E4H","title":"Use a diagnostic-native Eldr menu bar design","decision":"Use a monochrome Eldr template mark in the menu bar and a warm native diagnostic hierarchy that foregrounds the active resource culprit.","alternatives":[{"option":"Plain metric grid","why_rejected":"It hides Eldr identity and makes the resource culprit hard to scan."},{"option":"Full-color app icon in menu bar","why_rejected":"It does not adapt to macOS menu bar contrast at small sizes."}],"scope":["menubar/EldrMenu.swift,assets/eldr-menubar-template.*,Makefile"],"commits":["0088574c005f1bafe4b234507298beed1c4f16fc"],"author":"codex","confidence":"medium","tags":["ui,macos,menubar"],"ts":1783634621287}

{"schema":1,"kind":"decision","id":"01KX4FA4GXG0F8RJ862BYAG81G","title":"Use AppKit status item for the Eldr menu bar mark","decision":"Use NSStatusItem and NSStatusBarButton for the Eldr menu bar icon, with the existing SwiftUI monitor embedded in an NSPopover.","alternatives":[{"option":"SwiftUI MenuBarExtra label","why_rejected":"It reserves a blank selected item on this macOS runtime even when supplied a branded image."},{"option":"Colored text or emoji fallback","why_rejected":"It would mask the rendering defect instead of restoring native status-item behavior."}],"scope":["menubar/EldrMenu.swift"],"commits":["0088574c005f1bafe4b234507298beed1c4f16fc"],"author":"codex","confidence":"medium","tags":["macos,menubar,ui"],"ts":1783635448349}

{"schema":1,"kind":"decision","id":"01KX4H28NPHV0ZVHJMBNCQ6MZG","title":"Defer Eldr cask until the app passes Gatekeeper","decision":"Keep Homebrew formulae CLI-only and distribute Eldr.app as a documented release ZIP until Developer ID signing and notarization are available.","alternatives":[{"option":"Ship an Eldr cask now","why_rejected":"The current ad-hoc-signed app is rejected by Gatekeeper on Apple Silicon."},{"option":"Build Eldr.app inside the formula","why_rejected":"Homebrew formula policy directs native macOS apps to casks instead."}],"scope":["README.md,Formula/eldr.rb,Casks/eldr.rb"],"commits":["0088574c005f1bafe4b234507298beed1c4f16fc"],"author":"codex","confidence":"medium","tags":["release,distribution,homebrew"],"ts":1783637287606}
